PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/erm_platform
JWT_SECRET=your_secret_key_here

# Comma-separated list of allowed CORS origins (no spaces).
# Example: https://app.tactic-erm.com,https://admin.tactic-erm.com
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# AI module base URL (used by health check + AI proxy)
AI_MODULE_URL=http://localhost:8001

# Log level: error | warn | info | http | debug
LOG_LEVEL=info
LLAMA_CLOUD_API_KEY=
GROQ_API_KEY=

# SMTP for email OTP (use Gmail app-password, Mailtrap, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Tac-Tic ERM <no-reply@tactic-erm.local>"
APP_NAME=Tac-Tic ERM

# Google OAuth — Web application client ID from Google Cloud Console
GOOGLE_CLIENT_ID=
